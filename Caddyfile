{
    email faithconnect2020@gmail.com
}

# Match both the root domain AND all subdomains
build.faithconnect.us, *.build.faithconnect.us {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }

    # Handle Project Previews
    @preview {
        header_regexp preview_host Host ^p(\d+)-.+\.build\.faithconnect\.us$
    }

    handle @preview {
        reverse_proxy app:{re.preview_host.1} {
            # CRITICAL FOR STREAMING:
            header_up -Accept-Encoding
            flush_interval -1
        }
    }

    # Fallback (Main Site)
    handle {
        reverse_proxy app:3000 {
            # CRITICAL FOR STREAMING:
            header_up -Accept-Encoding
            flush_interval -1
        }
    }

    log {
        output file /data/access.log
    }
}