{
    # Cloudflare terminates TLS
    auto_https off
}

# Main app + all preview subdomains
build.faithconnect.us, *.build.faithconnect.us {

    log {
        output file /data/access.log
    }

    # Match preview hostnames like:
    # p3001-projectId.build.faithconnect.us
    @preview {
        header_regexp host Host ^p(\d+)-.+\.build\.faithconnect\.us$
    }

    # Route preview traffic to dynamic port
    handle @preview {
        reverse_proxy app:{re.host.1}
    }

    # Default app
    handle {
        reverse_proxy app:3000
    }
}