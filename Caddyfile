{
    email c4j@faithconnect.us
    on_demand_tls {
        ask http://app:3000/api/caddy/ask
        interval 2m
        burst 5
    }
}

build.faithconnect.us {
    reverse_proxy app:3000
}

:443 {
    tls {
        on_demand
    }

    # Match preview subdomains
    @preview host_regexp preview ^[a-z0-9-]+\.build\.faithconnect\.us$
    
    handle @preview {
        reverse_proxy app:3000
    }

    # Fallback for unknown domains
    handle {
        respond "Not Found" 404
    }
}
