{
    email c4j@faithconnect.us
    on_demand_tls {
        ask http://app:3000/api/caddy/ask
    }
}

# 1. Main Application
build.faithconnect.us {
    log {
        output file /data/access.log
    }
    reverse_proxy app:3000
}

# 2. Project Previews (Wildcard)
*.build.faithconnect.us {
    # Matches p{port}-{projectId}.build.faithconnect.us
    # The port is extracted from the p{port}- prefix.
    @preview {
        header_regexp host Host ^p(\d+)-.+\.build\.faithconnect\.us$
    }

    tls {
        on_demand
    }
    log {
        output file /data/preview_access.log
    }

    # Handle prefixed ports
    handle @preview {
        reverse_proxy app:{re.host.1}
    }

    # Fallback to default app port
    handle {
        reverse_proxy app:3000
    }
}
